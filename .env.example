# ─── Database ─────────────────────────────────────────────────────────────────
# Runtime URL (used by the app at runtime).
# Local Docker: postgresql://postgres:postgres@localhost:5433/pc_gateway
# Supabase:     use the Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pc_gateway

# Migration URL (used by Prisma CLI only — must be a direct connection).
# Poolers break Prisma's migration protocol, so this must bypass pgBouncer.
# Local Docker: same as DATABASE_URL
# Supabase:     use the Direct connection (port 5432) or Session pooler
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pc_gateway

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3002

# Public URL of this gateway — REQUIRED for payment redirect links to work.
# Without this, payment links fall back to localhost, which Telegram rejects.
# Local dev: use an ngrok/tunnel URL, e.g. https://xxxx.ngrok.io
# Production: your actual domain, e.g. https://gateway.example.com
# GATEWAY_PUBLIC_URL=https://gateway.example.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_EXPIRES_IN=1d

# ─── Admin account (created on first run if no admin exists) ──────────────────
# IMPORTANT: Change the password immediately after your first login!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── File uploads (business permits) ─────────────────────────────────────────
# Local path where uploaded permit/document files are stored.
UPLOAD_DIR=./uploads

# ─── Email (nodemailer — Gmail App Password) ──────────────────────────────────
# Used for order confirmations and store approval notifications.
# Gmail: enable 2FA then generate an App Password at myaccount.google.com/apppasswords
# Leave blank to disable email notifications.
EMAIL_USER=
EMAIL_APP_PASSWORD=

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Fallback bot token for local dev. In production the token is stored in the
# database (set it via the gateway admin panel → Settings tab).
# Create a bot via @BotFather on Telegram, then paste the token here.
# Leave blank to disable the Telegram bot.
TELEGRAM_BOT_TOKEN=

# ─── AI Chat (Anthropic Claude) ───────────────────────────────────────────────
# Powers the AI Assistant inside the Telegram bot.
# Get your key at: https://console.anthropic.com
# In production this is stored per-store in the database (via seller admin Settings → AI).
# Leave blank to disable AI chat (browse-only mode still works).
ANTHROPIC_API_KEY=

# ─── Mock Payment (optional) ──────────────────────────────────────────────────
# Set to true to enable the /mock-pay hosted checkout page in production.
# Safe to enable for demos and testing. Off by default for security.
# ENABLE_MOCK_PAYMENT=true
