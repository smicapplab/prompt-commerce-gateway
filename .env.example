# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:    postgresql://postgres:postgres@localhost:5432/pc_gateway
# Supabase:     postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pc_gateway

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3002

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# ─── Admin account (created on first run if no admin exists) ──────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── File uploads (business permits) ─────────────────────────────────────────
# Local path where uploaded permit files are stored
UPLOAD_DIR=./uploads

# ─── Steve