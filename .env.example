# ─── Database ─────────────────────────────────────────────────────────────────
# Runtime URL (used by the app). For Supabase use the Transaction pooler (port 6543).
# Local Docker: postgresql://postgres:postgres@localhost:5433/pc_gateway
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pc_gateway

# Migration URL (used by Prisma CLI). Must be a direct connection — poolers break migrations.
# For Supabase: use the Direct connection (port 5432).
# If port 5432 is blocked (e.g. EC2), use the Session pooler on port 5432 of the pooler host.
# Local Docker: same as DATABASE_URL
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pc_gateway

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3002

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# ─── Admin account (created on first run if no admin exists) ──────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── File uploads (business permits) ─────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Email (nodemailer — Gmail App Password) ──────────────────────────────────
# Used for order confirmations and store notifications.
# Gmail: enable 2FA then generate an App Password at myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_APP_PASSWORD=

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token here.
# Leave blank to disable the Telegram bot.
TELEGRAM_BOT_TOKEN=

# ─── AI Chat (Anthropic Claude) ───────────────────────────────────────────────
# Powers the AI Assistant inside the Telegram bot.
# Get your key at: https://console.anthropic.com
# Leave blank to disable AI chat (browse-only mode still works).
ANTHROPIC_API_KEY=
