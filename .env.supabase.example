# ─── Prompt Commerce Gateway — Supabase / Production Environment ──────────────
#
# Copy this file to .env when deploying to Supabase / production.
#
# Where to find your Supabase URLs:
#   Supabase Dashboard → Settings → Database → Connection string
#
# ─── Database ─────────────────────────────────────────────────────────────────

# Runtime URL — Supabase Transaction pooler (pgBouncer), port 6543
# Dashboard: "Transaction" mode
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Migration URL — must bypass pgBouncer (Prisma uses extended query protocol).
# Option A (preferred): Supabase Direct connection, port 5432
#   Dashboard: "Direct connection" mode
#   Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Option B (if port 5432 is blocked, e.g. EC2): Supabase Session pooler, port 5432
#   Dashboard: "Session" mode
#   Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres?sslmode=require

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3002

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── Admin account ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Email (nodemailer — Gmail App Password) ──────────────────────────────────
# Gmail: enable 2FA then generate an App Password at myaccount.google.com/apppasswords
EMAIL_USER=your@gmail.com
EMAIL_APP_PASSWORD=REPLACE_WITH_APP_PASSWORD

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token here.
# Leave blank to disable the Telegram bot.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN

# ─── AI Chat (Anthropic Claude) ───────────────────────────────────────────────
# Powers the AI Assistant inside the Telegram bot.
# Get your key at: https://console.anthropic.com
# Leave blank to disable AI chat (browse-only mode still works).
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY
