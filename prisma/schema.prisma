generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7 requirement).
  // See prisma.config.ts for local vs Supabase URL configuration.
}

// ─── Admin users (gateway operators) ─────────────────────────────────────────
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

// ─── Registered retailers ─────────────────────────────────────────────────────
model Retailer {
  id               Int               @id @default(autoincrement())
  slug             String            @unique                     // e.g. "steves-sari-sari"
  name             String            @unique                     // Display name
  contactEmail     String            @map("contact_email")
  mcpServerUrl     String            @map("mcp_server_url")     // e.g. http://43.221.xx.xx:3001
  businessPermitUrl String?          @map("business_permit_url") // uploaded file path
  verified         Boolean           @default(false)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  platformKey      PlatformKey?
  auditLogs        AuditLog[]

  @@map("retailers")
}

// ─── Platform keys (one active key per retailer) ──────────────────────────────
model PlatformKey {
  id          Int       @id @default(autoincrement())
  retailerId  Int       @unique @map("retailer_id")
  key         String    @unique                      // gk_<48 hex chars>
  issuedAt    DateTime  @default(now()) @map("issued_at")
  revokedAt   DateTime? @map("revoked_at")          // null = active

  retailer    Retailer  @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@map("platform_keys")
}

// ─── Audit log (key events) ───────────────────────────────────────────────────
model AuditLog {
  id         Int      @id @default(autoincrement())
  retailerId Int      @map("retailer_id")
  event      String                                  // e.g. "key_issued", "key_revoked", "verified"
  meta       Json?                                   // extra context
  createdAt  DateTime @default(now()) @map("created_at")

  retailer   Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
