// ─── Registered retailers ─────────────────────────────────────────────────────
model Retailer {
  id                Int      @id @default(autoincrement())
  slug              String   @unique
  name              String   @unique
  contactEmail      String   @map("contact_email")
  mcpServerUrl      String   @map("mcp_server_url")
  businessPermitUrl String?  @map("business_permit_url")
  verified          Boolean  @default(false)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // ── Per-store AI config (powers Telegram bot AI assistant) ────────────────
  // Set automatically when seller saves AI settings (pushed via platform key).
  // aiProvider:     "gemini" | "claude"
  // aiApiKey:       provider API key stored in DB (not in .env)
  // aiModel:        optional override; defaults to provider's recommended model
  //                 Claude default: claude-haiku-4-5-20251001
  //                 Gemini default: gemini-1.5-flash
  // aiSystemPrompt: custom persona / instructions the store owner wrote; if
  //                 null the bot falls back to a sensible default.
  aiProvider     String? @map("ai_provider")
  aiApiKey       String? @map("ai_api_key")
  aiModel        String? @map("ai_model")
  aiSystemPrompt String? @map("ai_system_prompt")
  serperApiKey   String? @map("serper_api_key")

  // ── Telegram seller notifications ─────────────────────────────────────────
  // The store owner's Telegram chat ID. When set, the bot sends an order
  // notification here whenever a buyer places an order through this store.
  // The owner gets their chat ID by messaging the bot and using /myid.
  telegramNotifyChatId String? @map("telegram_notify_chat_id")

  // ── Per-store payment config ───────────────────────────────────────────────
  // paymentProvider: "mock" | "paymongo" | "stripe"
  // paymentApiKey:   secret key for the provider (never returned to client)
  // paymentPublicKey: public/publishable key (PayMongo pk_xxx, Stripe pk_xxx)
  // paymentWebhookSecret: used to verify incoming webhook signatures
  paymentProvider      String? @map("payment_provider")
  paymentApiKey        String? @map("payment_api_key")
  paymentPublicKey     String? @map("payment_public_key")
  paymentWebhookSecret String? @map("payment_webhook_secret")

  platformKey PlatformKey?
  auditLogs   AuditLog[]

  @@map("retailers")
}

// ─── Platform keys (one active key per retailer) ──────────────────────────────
model PlatformKey {
  id         Int       @id @default(autoincrement())
  retailerId Int       @unique @map("retailer_id")
  key        String    @unique
  issuedAt   DateTime  @default(now()) @map("issued_at")
  revokedAt  DateTime? @map("revoked_at")

  retailer Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@map("platform_keys")
}

// ─── Audit log (key events) ───────────────────────────────────────────────────
model AuditLog {
  id         Int      @id @default(autoincrement())
  retailerId Int      @map("retailer_id")
  event      String
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  retailer Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
