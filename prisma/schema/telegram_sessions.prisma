// ─── Telegram sessions (customer state) ──────────────────────────────────────
// Stores session state for users interacting with the Telegram bot.
model TelegramSession {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  type      String   // "checkout" | "ai" | "search" | "browse"
  data      Json
  expiresAt DateTime @map("expires_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("telegram_sessions")
}
