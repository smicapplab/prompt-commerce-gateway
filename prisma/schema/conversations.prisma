// ─── Conversations ───────────────────────────────────────────────────────────
// Persistent chat sessions between a buyer (Telegram) and a store (AI/Human).
model Conversation {
  id          Int      @id @default(autoincrement())
  storeSlug   String   @map("store_slug")
  buyerRef    String   @map("buyer_ref")    // Telegram user ID
  buyerName   String?  @map("buyer_name")   // Telegram first_name / username
  channel     String   @default("telegram")
  mode        String   @default("ai")       // "ai" | "human" | "closed"
  assignedTo  String?  @map("assigned_to")  // Admin username
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages    Message[]
  retailer    Retailer  @relation(fields: [storeSlug], references: [slug], onDelete: Cascade)

  @@unique([buyerRef, storeSlug, channel])
  @@index([storeSlug])
  @@index([buyerRef])
  @@map("conversations")
}

// ─── Messages ─────────────────────────────────────────────────────────────────
// Thread of messages within a conversation.
model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  senderType     String   @map("sender_type") // "buyer" | "ai" | "human" | "system"
  senderName     String?  @map("sender_name") // "AI Bot" | human username | null
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}
