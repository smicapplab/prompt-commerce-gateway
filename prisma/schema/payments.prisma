// ─── Payments ─────────────────────────────────────────────────────────────────
// One row per payment attempt. Created when checkout is initiated;
// status updated when the provider webhooks back (or immediately for mock).

model Payment {
  id          Int     @id @default(autoincrement())
  referenceId String  @unique @map("reference_id") // provider's transaction ID
  storeSlug   String  @map("store_slug")
  orderId     Int     @map("order_id") // seller-side SQLite order ID
  buyerRef    String  @map("buyer_ref") // Telegram userId (as string)
  amount      Float // total in major currency units (e.g. 1500.00)
  currency    String  @default("PHP")
  provider    String // mock | paymongo | stripe
  status      String  @default("pending") // pending | paid | failed
  paymentUrl  String? @map("payment_url") // redirect URL for real gateways
  successUrl  String? @map("success_url") // internal success redirect
  cancelUrl   String? @map("cancel_url") // internal cancel redirect

  // New order-tracking fields
  orderStatus         String    @default("pending") @map("order_status") // mirrors seller-side status
  deliveryType        String    @default("delivery") @map("delivery_type")
  trackingNumber      String?   @map("tracking_number")
  courierName         String?   @map("courier_name")
  trackingUrl         String?   @map("tracking_url")
  cancellationReason  String?   @map("cancellation_reason")
  paymentInstructions String?   @map("payment_instructions") // shown to buyer for COD/Assisted
  orderCreatedAt      DateTime? @map("order_created_at") // seller's order.created_at
  terminalStatusAt    DateTime? @map("terminal_status_at") // when terminal status reached

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  orderNotes OrderNote[]
  orderFiles OrderFile[]

  @@unique([storeSlug, orderId])
  @@index([storeSlug, orderId])
  @@index([buyerRef])
  @@map("payments")
}
